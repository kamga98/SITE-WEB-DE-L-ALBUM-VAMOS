<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title> VAMOS </title>  

    <style> 
        body {  
            margin: 0;
            font-family: Arial, sans-serif;
            background: #0d0d0d;
            color: white;
        }

        .hero {
            display: flex;
            flex-wrap: wrap;
            padding: 50px;
            gap: 40px;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1f1f1f, #000);
        }

        .cover {
            flex: 1 1 300px;
            max-width: 350px;
        }

        .cover img {
            width: 100%;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        }

        .info {
            flex: 1 1 300px;
        }

        .artist {
            font-size: 22px;
            color: #b3b3b3;
            margin-bottom: 5px;
        }

        .title {
            font-size: 40px;
            margin: 0;
        }

        .meta {
            margin-top: 10px;
            color: #888;
        }

        .tracks {
            padding: 40px;
        }

        .tracks h2 {
            margin-bottom: 20px;
        }

        .track-list {
            list-style: none;
            padding: 0;
            max-width: 700px;
            margin: auto;
        }

        .track {
            display: flex;
            justify-content: space-between;
            padding: 15px;
            border-bottom: 1px solid #222;
            transition: background 0.2s;
        }

        .track:hover {
            background: #1a1a1a;
        }

        .number {
            color: #888;
            width: 30px;
        }

        .name {
            flex: 1;
        }

        .duration {
            color: #888;
        }

        @media (max-width: 768px) {
            .hero {
                flex-direction: column;
                text-align: center;
            }
        }
    </style>
</head>

<body>

    <div class="hero">  

